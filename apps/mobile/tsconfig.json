{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // No `baseUrl` — deprecated in TS 6 and removed in 7. Since TS 4.1 `paths`
    // resolves relative to this file's directory, so `@/*` still maps to
    // apps/mobile/* with identical behaviour.
    "paths": {
      "@/*": ["./*"]
    },
    "lib": ["ES2022", "DOM"],
    "types": ["expo/types"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"],
  "exclude": ["node_modules"]
}
