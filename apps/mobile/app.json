{
  "expo": {
    "name": "Sara Asset",
    "slug": "sara-asset-app",
    "scheme": "saraasset",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "bundleIdentifier": "com.Sara.assetapp",
      "buildNumber": "1",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.Sara.assetapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04fc306d-1109-4b7f-9d58-56e9a4c21710"
      }
    },
    "owner": "milk88084"
  }
}
