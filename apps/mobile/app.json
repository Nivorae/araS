{
  "expo": {
    "name": "Sara Asset",
    "slug": "sara-asset-app",
    "scheme": "saraasset",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.Sara.assetapp",
      "supportsTablet": true
    },
    "android": {
      "package": "com.Sara.assetapp"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
