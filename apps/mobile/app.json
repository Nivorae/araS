{
  "expo": {
    "name": "Sara Asset",
    "slug": "sara-asset-app",
    "scheme": "saraasset",
    "platforms": ["ios", "android"],
    "version": "1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/04fc306d-1109-4b7f-9d58-56e9a4c21710"
    },
    "ios": {
      "bundleIdentifier": "com.Sara.assetapp",
      "buildNumber": "1",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:ara-s-web.vercel.app"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.Sara.assetapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "blockedPermissions": ["com.google.android.gms.permission.AD_ID"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "ara-s-web.vercel.app" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04fc306d-1109-4b7f-9d58-56e9a4c21710"
      }
    },
    "owner": "milk88084"
  }
}
