# Expo client env vars must be prefixed EXPO_PUBLIC_ to be inlined into the app.

# Base URL of the existing Next.js API (apps/web).
# On a REAL DEVICE, localhost points at the phone, not your computer — use your
# machine's LAN IP and make sure `pnpm dev` is reachable on that IP:port.
# Find it with: ipconfig (Windows) -> IPv4 Address.
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# Same Clerk instance as the web app — copy the publishable key from .env
# (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY). Safe to expose; it is a public key.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Error monitoring (Sentry) — same DSN convention as apps/web (not a secret).
# Leave blank to disable; requires a new EAS build to take effect (native module).
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat (v2 IAP scaffolding) — public SDK keys, safe to expose client-side.
# Leave blank to disable (Paywall screen shows "coming soon" with no products).
# Requires a new EAS build to take effect (native module).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
