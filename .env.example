# Application
NODE_ENV=development

# Database (Supabase)
# Only define DATABASE_URL once — duplicates cause hard-to-debug connection issues
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Next.js public env vars (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Turborepo Remote Cache (optional, leave blank for local-only cache)
# TURBO_TOKEN=your_vercel_token
# TURBO_TEAM=your_vercel_team

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/assets
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/assets

# Market Data
# Server-side only — never expose to the mobile/web client. Optional fallback for
# US-stock/crypto quotes when Yahoo Finance's unofficial API fails or rate-limits.
# Free tier (60 req/min): https://finnhub.io. Leave blank to disable (Yahoo-only).
FINNHUB_API_KEY=

# Error monitoring (Sentry) — sentry.io free tier. The DSN is not a secret (it's
# meant to be embedded in client bundles) — same value is used client/server/edge.
# Leave blank to disable; nothing breaks without it.
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed to upload source maps at build time (Project Settings ->
# Client Keys for org/project slugs; Settings -> Auth Tokens for the token).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# App Store Server Notifications webhook (v2 IAP scaffolding — not live until
# a real subscription product exists and this URL is registered in App Store
# Connect). Not a secret, but must be the real DER bytes of Apple's root CA —
# download from https://www.apple.com/certificateauthority/ then:
#   base64 -i AppleRootCA-G3.cer | tr -d '\n'
# Leave blank and the webhook just acks 200 without processing anything.
APPLE_ROOT_CA_CERTS_BASE64=
